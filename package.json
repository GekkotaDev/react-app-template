{
  "name": "react-app",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "start": "mprocs",
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build && cap sync",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest --project unit --tags-filter=unit",
    "test:integration": "vitest --project browser --tags-filter=integration",
    "test:staging": "vitest --project browser --tags-filter=staging",
    "test:stories": "vitest --project browser --tags-filter=storybook",
    "spec": "vitest --no-open --ui --tags-filter='unit and story'",
    "storybook:dev": "storybook dev --no-open -p 6006",
    "storybook:build": "storybook build",
    "generate": "plop",
    "g": "plop"
  },
