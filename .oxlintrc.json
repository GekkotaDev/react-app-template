{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["**/*.gen.ts"],
  "plugins": [
    "import",
    "jsdoc",
    "jsx-a11y",
    "promise",
    "react",
    "react-perf",
    "vitest",
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "options": {
    "typeAware": true
  },
  "settings": {
    "vitest": {
      "typecheck": true
    }
  },
  "rules": {},
  "env": {
    "builtin": true
  }
}
